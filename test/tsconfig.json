{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "rootDir": "..",
        "outDir": "../dist/test",
        "composite": false,
        "declaration": false,
        "declarationMap": false,
        "noEmit": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": "..",
        "paths": {
            "auth-h3client/v1": [
                "./packages/client-h3v1/src/main.ts"
            ],
            "auth-h3client/v2": [
                "./packages/client-h3v2/src/main.ts"
            ],
            "@internal/shared": [
                "./packages/shared/src/index.ts"
            ]
        }
    },
    "include": [
        "./**/*.ts",
        "../packages/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}