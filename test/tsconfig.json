{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "rootDir": "..",
        "outDir": "../dist/test",
        "composite": false,
        "declaration": false,
        "declarationMap": false,
        "noEmit": true,
        "baseUrl": "..",
        "paths": {
            "@internal/shared": [
                "./packages/shared/src/index.ts"
            ]
        }
    },
    "include": [
        "./**/*.ts",
        "../packages/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}