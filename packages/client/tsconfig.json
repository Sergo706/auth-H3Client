{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "paths": {
            "@internal/shared": [
                    "../shared/src/index.ts"
                ]
        }
    },
    "references": [
            {
                "path": "../shared"
            }
        ],
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
