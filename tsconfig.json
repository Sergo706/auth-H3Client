{
  "compilerOptions": {
    "target": "ES2022",                                 
    "module": "nodenext",                                
     "rootDir": "./",                                  
     "moduleResolution": "nodenext",                    
    "outDir": "./dist",                                  
     "allowSyntheticDefaultImports": true,            
    "esModuleInterop": true,                           
    "forceConsistentCasingInFileNames": true,           
    "strict": true,           
    "resolveJsonModule": true,  
    "isolatedModules": true,                         
    "skipLibCheck": true,
    "noEmitOnError": true                      
  },
  "include": ["src/**/*", "test", "src/utils", "test/testAuthController.ts", "test/smoke/controllers.test/test.ts"],
  "exclude": ["node_modules"]
}
