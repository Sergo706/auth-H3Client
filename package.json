{
  "name": "@riavzon/auth-h3client",
  "version": "1.0.13",
  "author": "Sergio contact@riavzon.com",
  "type": "module",
  "main": "./dist/v1.js",
  "types": "./dist/v1.d.ts",
  "license": "Apache-2.0",
  "description": "H3 middleware, routes and client utilities for the Riavzon Auth service - includes magic links, OAuth/OIDC helpers, CSRF issuance/verification, token management, and optional mTLS support.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sergo706/auth-H3Client"
  },
  "homepage": "https://docs.riavzon.com/docs/auth-h3client",
  "bugs": {
    "url": "https://github.com/Sergo706/auth-H3Client/issues"
  },
  "keywords": [
    "auth",
    "authentication",
    "h3",
    "nuxt",
    "magic-links",
    "oauth",
    "oidc",
    "csrf",
    "mfa",
    "middleware",
    "hmac",
    "mtls",
    "email"
  ],
  "workspaces": [
    "packages/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/v1.d.ts",
      "import": "./dist/v1.js",
      "default": "./dist/v1.js"
    },
    "./v1": {
      "types": "./dist/v1.d.ts",
      "import": "./dist/v1.js",
      "default": "./dist/v1.js"
    },
    "./v2": {
      "types": "./dist/v2.d.ts",
      "import": "./dist/v2.js",
      "default": "./dist/v2.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js",
      "default": "./dist/module.js"
    },
    "./server/middleware": {
      "types": "./dist/server/middleware.d.ts",
      "import": "./dist/server/middleware.js",
      "default": "./dist/server/middleware.js"
    },
    "./server/routes": {
      "types": "./dist/server/routes.d.ts",
      "import": "./dist/server/routes.js",
      "default": "./dist/server/routes.js"
    },
    "./server/templates": {
      "types": "./dist/server/templates.d.ts",
      "import": "./dist/server/templates.js",
      "default": "./dist/server/templates.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "v1": [
        "dist/v1.d.ts"
      ],
      "v2": [
        "dist/v2.d.ts"
      ],
      "client": [
        "dist/client.d.ts"
      ],
      "module": [
        "dist/module.d.ts"
      ],
      "server/middleware": [
        "dist/server/middleware.d.ts"
      ],
      "server/routes": [
        "./dist/server/routes.d.ts"
      ],
      "server/templates": [
        "dist/server/templates.d.ts"
      ],
      "*": [
        "dist/v1.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup",
    "test": "vitest run --no-coverage",
    "start": "node dist/test/server.js",
    "docs:dev": "vitepress dev",
    "docs:build": "typedoc --options ./typedoc.json && vitepress build",
    "docs:preview": "vitepress preview",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "h3": "^1.15.4 || ^2.0.0-beta.4",
    "nitropack": "^2.13.1",
    "nuxt": "^4.2.2 || ^3.0.0",
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@nuxt/kit": "^3.17.0 || ^4.0.0",
    "file-type": "21.3.0",
    "he": "1.2.0",
    "jose": "6.1.0",
    "pino": "9.11.0",
    "sanitize-html": "2.17.0",
    "sharp": "0.34.5",
    "ts-node": "10.9.2",
    "undici": "7.16.0",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "17.2.3",
    "mysql2": "^3.16.3",
    "tsup": "8.5.1",
    "typedoc": "0.28.16",
    "typedoc-plugin-markdown": "4.10.0",
    "typedoc-vitepress-theme": "1.1.2",
    "typescript": "5.6.3",
    "unstorage": "1.17.4",
    "vitepress": "1.6.4",
    "vitest": "^4.0.18"
  }
}
