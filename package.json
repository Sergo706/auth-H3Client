{
  "name": "auth-h3client",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "./dist/v1.js",
  "types": "./dist/v1.d.ts",
  "workspaces": [
    "packages/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/v1.d.ts",
      "import": "./dist/v1.js",
      "default": "./dist/v1.js"
    },
    "./v1": {
      "types": "./dist/v1.d.ts",
      "import": "./dist/v1.js",
      "default": "./dist/v1.js"
    },
    "./v2": {
      "types": "./dist/v2.d.ts",
      "import": "./dist/v2.js",
      "default": "./dist/v2.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js",
      "default": "./dist/module.js"
    },
    "./server/middleware": {
      "types": "./dist/server/middleware.d.ts",
      "import": "./dist/server/middleware.js",
      "default": "./dist/server/middleware.js"
    },
    "./server/routes": {
      "types": "./dist/server/routes.d.ts",
      "import": "./dist/server/routes.js",
      "default": "./dist/server/routes.js"
    },
    "./server/templates": {
      "types": "./dist/server/templates.d.ts",
      "import": "./dist/server/templates.js",
      "default": "./dist/server/templates.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "v1": [
        "dist/v1.d.ts"
      ],
      "v2": [
        "dist/v2.d.ts"
      ],
      "client": [
        "dist/client.d.ts"
      ],
      "module": [
        "dist/module.d.ts"
      ],
      "server/middleware": [
        "dist/server/middleware.d.ts"
      ],
      "server/routes": [
        "./dist/server/routes.d.ts"
      ],
      "server/templates": [
        "dist/server/templates.d.ts"
      ],
      "*": [
        "dist/v1.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "start": "node dist/test/server.js",
    "docs:dev": "vitepress dev",
    "docs:build": "typedoc --options ./typedoc.json && vitepress build",
    "docs:preview": "vitepress preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "h3": "^1.15.4 || ^2.0.0-beta.4",
    "nitropack": "^2.13.1",
    "nuxt": "^4.2.2 || ^3.0.0",
    "vue": "^3.5.18"
  },
  "dependencies": {
    "@nuxt/kit": "^3.17.0",
    "file-type": "^21.3.0",
    "he": "^1.2.0",
    "jose": "^6.1.0",
    "pino": "^9.11.0",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "telegraf": "^4.16.3",
    "ts-node": "^10.9.2",
    "undici": "^7.16.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "dotenv": "^17.2.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.6.3",
    "unstorage": "^1.17.4",
    "vitepress": "^1.6.4"
  }
}
